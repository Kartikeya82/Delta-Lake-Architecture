from pyspark.sql import SparkSession
from pyspark.sql.functions import *
from pyspark.sql.types import *
from pyspark.ml import PipelineModel

# ======================
# SPARK SESSION
# ======================
spark = SparkSession.builder \
    .appName("Final Lakehouse Pipeline") \
    .config("spark.sql.shuffle.partitions", "4") \
    .config("spark.hadoop.fs.permissions.enabled", "false") \
    .getOrCreate()

spark.sparkContext.setLogLevel("ERROR")

BASE = "/home/puru/social_media_lakehouse"

# ======================
# LOAD TRAINED MODEL
# ======================
MODEL_PATH = f"{BASE}/models/lr_model_final"
model = PipelineModel.load(MODEL_PATH)

# ======================
# KAFKA SOURCE
# ======================
df_kafka = spark.readStream \
    .format("kafka") \
    .option("kafka.bootstrap.servers", "localhost:9092") \
    .option("subscribe", "twitter_stream") \
    .option("startingOffsets", "latest") \
    .load()

df_json = df_kafka.selectExpr("CAST(value AS STRING)")

# ======================
# SCHEMA
# ======================
schema = StructType([
    StructField("target", IntegerType()),
    StructField("id", LongType()),
    StructField("date", StringType()),
    StructField("flag", StringType()),
    StructField("user", StringType()),
    StructField("text", StringType())
])

df = df_json.select(from_json(col("value"), schema).alias("data")).select("data.*")

# ======================
# 🥉 BRONZE
# ======================
df.writeStream \
    .format("parquet") \
    .outputMode("append") \
    .option("checkpointLocation", f"{BASE}/checkpoints/bronze") \
    .start(f"{BASE}/data/bronze")

# ======================
# 🥈 SILVER
# ======================
cleaned = df \
    .withColumn("text", lower(col("text"))) \
    .withColumn("text", regexp_replace(col("text"), "http\\S+", "")) \
    .withColumn("text", regexp_replace(col("text"), "@\\w+", "")) \
    .withColumn("sentiment",
        when(col("target") == 4, "positive").otherwise("negative")
    ) \
    .drop("flag")

cleaned.writeStream \
    .format("parquet") \
    .outputMode("append") \
    .option("checkpointLocation", f"{BASE}/checkpoints/silver") \
    .start(f"{BASE}/data/silver")

# ======================
# ADD TIMESTAMP
# ======================
cleaned_ts = cleaned.withColumn("timestamp", current_timestamp())

# ======================
# 🥇 GOLD — ANALYTICS (KEEP)
# ======================
sentiment_counts = cleaned_ts \
    .withWatermark("timestamp", "1 minute") \
    .groupBy(window(col("timestamp"), "30 seconds"), col("sentiment")) \
    .count()

sentiment_counts.writeStream \
    .format("parquet") \
    .outputMode("append") \
    .option("checkpointLocation", f"{BASE}/checkpoints/gold_sentiment") \
    .start(f"{BASE}/data/gold/sentiment")

# ======================
# 🤖 GOLD — ENRICHED (ML FINAL)
# ======================
predictions = model.transform(cleaned_ts)

enriched_gold = predictions.select(
    "text",
    "user",
    "timestamp",
    "sentiment",
    col("prediction").alias("predicted_sentiment"),
    (abs(col("prediction") - when(col("sentiment") == "positive", 1).otherwise(0))).alias("error")
)

enriched_gold.writeStream \
    .format("parquet") \
    .outputMode("append") \
    .option("checkpointLocation", f"{BASE}/checkpoints/gold_enriched") \
    .start(f"{BASE}/data/gold/enriched")

# ======================
# OPTIONAL: VIEW OUTPUT
# ======================
enriched_gold.writeStream \
    .format("console") \
    .outputMode("append") \
    .start()

# ======================
# RUN
# ======================
spark.streams.awaitAnyTermination()
